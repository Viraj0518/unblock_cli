{
  "name": "@unblock/cli",
  "version": "0.1.1",
  "description": "Standalone `unblock` command-line binary for UNBLOCK. Distributed via npm. Exposes comms (chat/say/dm/ask), substrate (remember/query), and auth (login/whoami/logout) over NATS + HTTP.",
  "keywords": [
    "unblock",
    "cli",
    "command-line",
    "tool"
  ],
  "license": "Apache-2.0",
  "author": "Viraj-Alpha <virajsharma@kaeva.app>",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Viraj0518/unblock_cli.git"
  },
  "homepage": "https://github.com/Viraj0518/unblock_cli#readme",
  "bugs": {
    "url": "https://github.com/Viraj0518/unblock_cli/issues"
  },
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "unblock": "./dist/main.js"
  },
  "exports": null,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "unblock-skill.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check-boundaries": "node scripts/check-boundaries.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo coverage",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test && pnpm lint && pnpm check-boundaries"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "nats": "^2.28.0",
    "prompts": "^2.4.0"
  },
  "pkg": {
    "scripts": ["dist/comms/nats-client.js"],
    "assets": ["node_modules/nats/**/*"],
    "targets": ["node22"]
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@yao-pkg/pkg": "6.20.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
